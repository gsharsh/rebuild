# Supabase — Auth (and resume upload storage)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# FastAPI backend — sessions, questions, AI coaching
NEXT_PUBLIC_API_URL="http://localhost:8000"

# Gemini — SERVER ONLY. Never use NEXT_PUBLIC_ prefix.
GEMINI_API_KEY="your-gemini-api-key"

# ElevenLabs — SERVER ONLY (Person 1). Never use NEXT_PUBLIC_ prefix!
# Restart `npm run dev` after adding these.
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
ELEVENLABS_VOICE_ID="your-voice-id-or-leave-default"

# Valence — SERVER ONLY. Never use NEXT_PUBLIC_ prefix.
VALENCE_API_KEY="your-valence-api-key"
VALENCE_API_BASE_URL="https://api.getvalenceai.com"
VALENCE_WEBSOCKET_URL="wss://api.getvalenceai.com"
VALENCE_LOG_LEVEL="INFO"
FFMPEG_PATH="/opt/homebrew/bin/ffmpeg"
