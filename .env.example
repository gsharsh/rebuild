# Supabase — Auth (and resume upload storage)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# FastAPI backend — sessions, questions, Gemini script coach
NEXT_PUBLIC_API_URL="http://localhost:8000"

# ElevenLabs — SERVER ONLY (Person 1). Never use NEXT_PUBLIC_ prefix!
# Restart `npm run dev` after adding these.
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
ELEVENLABS_VOICE_ID="your-voice-id-or-leave-default"
